<%= simple_form_for @proyectofinanciero do |f| %>
  <%= f.simple_fields_for :objetivopf_proyectofinanciero,
    child_index: params[:index] do |subf| %>
    <%= turbo_stream.replace "agregar-objetivopf-proyectofinanciero" do %>
      <%= f.submit "Agregar #{Cor1440Gen::Proyectofinanciero.human_attribute_name(:Objetivopf)}",
        formaction: cor1440_gen.crear_objetivopf_proyectofinanciero_path(
          subf.index.to_i + 1
        ),
        formmethod: :post,
        formnovalidate: true,
        class: 'btn btn-sm btn-primary',
        id: "agregar-objetivopf-proyectofinanciero",
        data:  {
          disable_with: false
        } %>
    <% end %>

    <%= turbo_stream.append "objetivospf_proyectofinanciero_marco" do %>
      <%= render(
        partial: "/cor1440_gen/proyectosfinancieros/objetivopf_campos",
        locals: {
          f: subf,
          relacion: :objetivopf_proyectofinanciero,
          ruta_eliminar: cor1440_gen.eliminar_objetivopf_proyectofinanciero_path
        }
      ) %>
    <% end %>
  <% end %>
<% end %>
